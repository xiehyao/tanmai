<view class="create-page">
  <view class="card">
    <textarea
      class="content-input"
      placeholder="这一刻的想法..."
      maxlength="600"
      value="{{content}}"
      bindinput="onContentInput"
    />
    <text class="counter">{{content.length}}/600</text>
  </view>

  <view class="card">
    <view class="section-title">图片</view>
    <view class="image-grid">
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image class="preview-image" src="{{item}}" mode="aspectFill" />
        <text class="remove-image" data-index="{{index}}" bindtap="removeImage">×</text>
      </view>
      <view class="image-add" wx:if="{{images.length < 9}}" bindtap="chooseImages">＋</view>
    </view>
  </view>

  <view class="card">
    <view class="signup-row">
      <text class="section-title">开启报名</text>
      <switch checked="{{enableSignup}}" bindchange="onToggleSignup" color="#667eea" />
    </view>
    <text class="signup-tip" wx:if="{{enableSignup}}">发布后在帖子详情中显示「报名/待定」与报名列表。</text>
  </view>

  <view class="bottom-actions">
    <button class="publish-btn" bindtap="publishPost" loading="{{publishing}}" disabled="{{publishing}}">发布</button>
  </view>
</view>
