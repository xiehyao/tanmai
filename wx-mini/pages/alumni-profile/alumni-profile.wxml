<!--pages/alumni-profile/alumni-profile.wxml-->
<view class="profile-page" wx:if="{{user}}">
  <scroll-view scroll-y class="profile-scroll">
    <!-- 1. 简介（新布局：姓名 + 大图 + 正文 + 帮我连连看） -->
    <view class="section">
      <view class="section-title">我的简介</view>
      <view class="card-card intro-card-v2">
        <text class="intro-name-head">{{displayName || ownerName}}</text>
        <image
          wx:if="{{introHeroUrl}}"
          class="intro-hero-img"
          src="{{introHeroUrl}}"
          mode="aspectFill"
        />
        <text class="intro-body-text" wx:if="{{introBodyText}}" user-select>{{introBodyText}}</text>
        <view class="intro-bio-empty" wx:else>
          <text class="intro-text-muted">暂无简介</text>
        </view>
        <view class="intro-pair-btn-wrap">
          <button class="pair-help-btn" bindtap="onPairHelpTap">帮我连连看</button>
        </view>
      </view>
    </view>

    <!-- 2. 名片（整块下移） -->
    <view class="section">
      <view class="section-title">我的名片</view>
      <view class="card-card my-card-style">
        <view class="card-row">
          <image
            class="card-avatar"
            src="{{user.display_avatar || user.avatar || user.selected_avatar || 'https://tanmai-1318644773.cos.ap-guangzhou.myqcloud.com/avatars/male-young-1.png'}}"
            mode="aspectFill"
          />
          <view class="card-main">
            <text class="card-name">{{user.name || user.nickname || '未设置'}}</text>
            <text class="card-company">{{(user.company || '') + (user.company && user.title ? ' ' : '') + (user.title || '')}}</text>
            <text class="card-meta card-meta-assoc" wx:if="{{displayAssociationTitle}}">{{displayAssociationTitle}}</text>
            <text class="card-meta" wx:if="{{user.phone}}">{{user.phone}}</text>
            <text class="card-meta" wx:if="{{user.email}}">{{user.email}}</text>
            <text class="card-meta" wx:if="{{user.wechat_id}}">微信：{{user.wechat_id}}</text>
            <text class="card-meta" wx:if="{{displayAddress}}">{{displayAddress}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 3. 校友连连看（点击展开与「帮我连连看」相同半屏，展示完整记录） -->
    <view class="section">
      <view class="section-title">校友连连看</view>
      <view class="card-card match-card-style match-card-tap" bindtap="onMatchCardTap" hover-class="match-card-hover">
        <view class="match-text">{{matchContent}}</view>
        <view class="match-tap-hint" wx:if="{{pairHasRecord}}">
          <text class="match-tap-hint-text">点击查看完整记录（含思考与追问）›</text>
        </view>
        <view class="match-tap-hint" wx:else>
          <text class="match-tap-hint-muted">点按查看说明 · 登录后在简介中「帮我连连看」可生成分析</text>
        </view>
      </view>
    </view>

    <view class="scroll-bottom-pad"></view>
  </scroll-view>

  <!-- 固定置底 bar -->
  <view class="fixed-bottom-bar">
    <view class="bar-left-group">
      <view class="bar-left">
        <image
          class="bar-avatar"
          src="{{user.display_avatar || user.avatar || user.selected_avatar || 'https://tanmai-1318644773.cos.ap-guangzhou.myqcloud.com/avatars/male-young-1.png'}}"
          mode="aspectFill"
        />
        <view class="bar-info">
          <text class="bar-name">{{user.name || user.nickname || '校友'}}</text>
          <text class="bar-follow">{{followFollowerCount}}个朋友关注</text>
        </view>
      </view>
      <view
        wx:if="{{showFollowBtn}}"
        class="bar-follow-btn {{followFollowing ? 'bar-follow-btn-on' : ''}}"
        bindtap="onFollowTap"
      >{{followFollowing ? '已关注' : '+关注'}}</view>
    </view>
    <view class="bar-icons">
      <view class="bar-icon-item">
        <text class="bar-icon">👍</text>
        <text class="bar-num">42</text>
      </view>
      <view class="bar-icon-item">
        <text class="bar-icon">↗</text>
        <text class="bar-num">42</text>
      </view>
      <view class="bar-icon-item">
        <text class="bar-icon">♥</text>
        <text class="bar-num">42</text>
      </view>
      <view class="bar-icon-item">
        <text class="bar-icon">💬</text>
        <text class="bar-num">168</text>
      </view>
    </view>
  </view>

  <!-- 双人连连看 3/4 半屏 -->
  <view class="pair-mask" wx:if="{{showPairSheet}}" catchtouchmove="stopPairTap" bindtap="closePairSheet"></view>
  <view class="pair-sheet" wx:if="{{showPairSheet}}" catchtap="stopPairTap">
    <view class="pair-sheet-header">
      <text class="pair-sheet-title">连连看 · 互助切入点</text>
      <text class="pair-sheet-close" bindtap="closePairSheet">关闭</text>
    </view>
    <scroll-view scroll-y class="pair-sheet-body" scroll-with-animation="{{true}}">
      <view wx:if="{{pairLoading && !pairStreamText}}" class="pair-loading-hint">AI 正在分析双方资料…</view>
      <view wx:if="{{pairFollowLoading && pairStreamText}}" class="pair-loading-hint">AI 正在回复追问…</view>
      <text class="pair-stream-text" user-select>{{pairStreamText}}</text>
    </scroll-view>
    <view class="pair-follow-bar">
      <input
        class="pair-follow-input"
        value="{{pairInputValue}}"
        bindinput="onPairInput"
        placeholder="输入追问，继续向 AI 提问…"
        confirm-type="send"
        bindconfirm="onPairFollowSubmit"
        disabled="{{pairLoading || pairFollowLoading || !pairAllowFollow}}"
      />
      <button class="pair-follow-send" bindtap="onPairFollowSubmit" disabled="{{pairLoading || pairFollowLoading || !pairAllowFollow}}">发送</button>
    </view>
  </view>
</view>
