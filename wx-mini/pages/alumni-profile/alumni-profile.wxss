/* pages/alumni-profile/alumni-profile.wxss */
.profile-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.profile-scroll {
  height: 100vh;
}

.section {
  margin-bottom: 32rpx;
}

/* 区块标题：仅作区隔，弱化 */
.section-title {
  font-size: 24rpx;
  font-weight: 400;
  color: #9ca3af;
  padding: 20rpx 28rpx 10rpx;
}

.card-card {
  margin: 0 28rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

/* 我的名片：与名片夹卡片布局一致，左头像右信息 */
.my-card-style {
  background: #fff;
  min-height: auto;
}

.my-card-style .card-row {
  display: flex;
}

.my-card-style .card-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}

.my-card-style .card-main {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.my-card-style .card-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.my-card-style .card-company {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
}

.my-card-style .card-meta {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
}

.match-card-style .match-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 8;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-word;
}

.match-card-tap {
  position: relative;
}

.match-card-hover {
  opacity: 0.92;
  background: #fafafa !important;
}

.match-tap-hint {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e5e7eb;
}

.match-tap-hint-text {
  font-size: 24rpx;
  color: #3b82f6;
}

.match-tap-hint-muted {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 简介卡片 v2：与参考图一致，无字段标签 */
.intro-card-v2 {
  background: #fff;
  padding: 32rpx 28rpx;
}

.intro-name-head {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 20rpx;
  line-height: 1.3;
}

.intro-hero-img {
  display: block;
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  background: #e5e7eb;
  margin-bottom: 24rpx;
}

.intro-body-text {
  display: block;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.75;
  white-space: pre-wrap;
  word-break: break-word;
}

.intro-bio-empty {
  padding: 16rpx 0;
}

.intro-text-muted {
  font-size: 28rpx;
  color: #9ca3af;
}

.intro-pair-btn-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  margin-top: 28rpx;
  padding-top: 8rpx;
}

.pair-help-btn {
  margin: 0;
  min-width: 280rpx;
  max-width: 90%;
  height: 80rpx;
  line-height: 80rpx;
  background: #cbd5e1;
  color: #334155;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  padding: 0 40rpx;
}

.pair-help-btn::after {
  border: none;
}

.pair-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
}

.pair-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 75vh;
  max-height: 75vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
}

.pair-follow-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e5e7eb;
  background: #fff;
}

.pair-follow-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f1f5f9;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.pair-follow-send {
  width: 140rpx;
  min-width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  margin: 0;
  font-size: 28rpx;
  background: #3b82f6;
  color: #fff;
  border-radius: 12rpx;
  border: none;
}

.pair-follow-send::after {
  border: none;
}

.pair-sheet-header {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.pair-sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.pair-sheet-close {
  font-size: 28rpx;
  color: #64748b;
  padding: 8rpx 0 8rpx 16rpx;
}

.pair-sheet-body {
  flex: 1;
  height: 0;
  min-height: 0;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

.pair-loading-hint {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 16rpx;
}

.pair-stream-text {
  font-size: 28rpx;
  color: #1e293b;
  line-height: 1.75;
  white-space: pre-wrap;
  word-break: break-word;
}

.scroll-bottom-pad {
  height: 40rpx;
}

/* 固定置底 bar - 左组(头像+姓名+按钮)紧凑 | 右组4图标留足空间 */
.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bar-left-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  min-width: 0;
}

.bar-left {
  display: flex;
  align-items: center;
  flex: 0 1 auto;
  min-width: 0;
  max-width: 240rpx;
  overflow: hidden;
}

.bar-avatar {
  width: 72rpx;
  height: 72rpx;
  min-width: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}

.bar-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

.bar-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bar-follow {
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 2rpx;
}

.bar-follow-btn {
  width: 120rpx;
  min-width: 120rpx;
  height: 56rpx;
  padding: 0;
  margin-left: 12rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #22c55e;
  color: #fff;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.bar-icons {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 1;
  margin-left: 40rpx;
  min-width: 0;
}

.bar-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  height: 64rpx;
  flex: 1;
}

.bar-icon {
  font-size: 36rpx;
  line-height: 40rpx;
  height: 40rpx;
  display: block;
  text-align: center;
}

.bar-num {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 6rpx;
  line-height: 1;
}
