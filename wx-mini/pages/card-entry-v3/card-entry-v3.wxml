      <view class="contact-type-item" wx:for="{{contactTypeGrid}}" wx:key="label" data-type="{{item.type}}" data-label="{{item.label}}" data-location-type="{{item.location_type}}" bindtap="onSelectContactType">
        <view class="contact-type-icon">{{item.type === 'phone' ? '📱' : item.type === 'landline' ? '☎' : item.type === 'email' ? '✉' : item.type === 'fax' ? '📠' : item.type === 'wechat' ? '💬' : item.type === 'qq' ? '🐧' : item.type === 'weibo' ? '🐦' : item.type === 'address' ? (item.location_type === 'residence' ? '🏠' : item.location_type === 'work' ? '🏢' : item.location_type === 'temp_event' ? '📍' : '📌') : item.type === 'linkedin' ? 'in' : '🔗'}}</view>
        <text class="contact-type-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 半屏：选择地址类型（点击某条地址右侧 + 时） -->
  <view class="sheet-mask" wx:if="{{showAddressTypeSheet}}" bindtap="closeAddressTypeSheet"></view>
  <view class="sheet-panel {{showAddressTypeSheet ? 'sheet-show' : ''}}" wx:if="{{showAddressTypeSheet}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeAddressTypeSheet">×</text>
      <text class="sheet-title">添加地址</text>
    </view>
    <view class="sheet-body need-type-grid-wrap">
      <view class="need-type-grid">
        <view class="need-type-item" wx:for="{{addressTypeGrid}}" wx:key="location_type" data-label="{{item.label}}" data-location-type="{{item.location_type}}" bindtap="onSelectAddressType">
          <text class="need-type-icon">{{item.icon}}</text>
          <text class="need-type-label">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 半屏：选择头像 -->
  <view class="sheet-mask" wx:if="{{showAvatarSheet}}" bindtap="closeAvatarSheet"></view>
  <view class="sheet-panel edu-sheet {{showAvatarSheet ? 'sheet-show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeAvatarSheet">×</text>
      <text class="sheet-title">选择头像</text>
    </view>
    <scroll-view class="sheet-body" scroll-y>
      <view class="avatar-grid">
        <view class="avatar-grid-item" wx:for="{{avatarOptions}}" wx:key="value" data-url="{{item.value}}" bindtap="onSelectAvatar">
          <image class="avatar-grid-img" src="{{item.value}}" mode="aspectFill" />
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 半屏：校董会职务选择（选项平铺） -->
  <view class="sheet-mask" wx:if="{{showBoardPositionSheet}}" bindtap="closeBoardPositionSheet"></view>
  <view class="sheet-panel edu-sheet {{showBoardPositionSheet ? 'sheet-show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeBoardPositionSheet">×</text>
      <text class="sheet-title">校董会职务</text>
    </view>
    <scroll-view class="sheet-body" scroll-y>
      <view class="board-option-row" wx:for="{{boardPositionOptions}}" wx:key="value" data-value="{{item.value}}" data-label="{{item.label}}" bindtap="onSelectBoardPosition">
        <text class="board-option-label">{{item.label}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 半屏：教育经历 - 先选学历层级（九宫格） -->
  <view class="sheet-mask" wx:if="{{showEduLevelSheet}}" bindtap="closeEduLevelSheet"></view>
  <view class="sheet-panel {{showEduLevelSheet ? 'sheet-show' : ''}}" wx:if="{{showEduLevelSheet}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeEduLevelSheet">×</text>
      <text class="sheet-title">选择学历层级</text>
    </view>
    <view class="sheet-body need-type-grid-wrap">
      <view class="need-type-grid">
        <view class="need-type-item" wx:for="{{eduLevelGrid}}" wx:key="degree" data-degree="{{item.degree}}" data-label="{{item.label}}" bindtap="onSelectEduLevel">
          <text class="need-type-icon">{{item.icon}}</text>
          <text class="need-type-label">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 半屏：添加/编辑教育经历 -->
  <view class="sheet-mask" wx:if="{{showEduSheet}}" bindtap="closeEduSheet"></view>
  <view class="sheet-panel edu-sheet {{showEduSheet ? 'sheet-show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeEduSheet">×</text>
      <text class="sheet-title">{{eduEditIndex >= 0 ? '编辑教育经历' : '添加教育经历'}}</text>
    </view>
    <scroll-view class="sheet-body" scroll-y>
      <view class="form-row">
        <text class="form-label">教育阶段 *</text>
        <picker class="form-picker" mode="selector" range="{{degreeOptions}}" bindchange="onEduDegreeChange">
          <view class="form-input">{{degreeLabel}}</view>
        </picker>
        <text class="form-arrow">></text>
      </view>
      <view class="form-row">
        <text class="form-label">学校 *</text>
        <input class="form-input" placeholder="必填" value="{{eduForm.school}}" data-field="school" bindinput="onEduFormInput" />
      </view>
      <view class="form-row" wx:if="{{eduForm.degree === '本科' || eduForm.degree === '硕士' || eduForm.degree === '博士'}}">
        <text class="form-label">院系</text>
        <input class="form-input" placeholder="如：计算机学院、经管学院" value="{{eduForm.department}}" data-field="department" bindinput="onEduFormInput" />
      </view>
      <view class="form-row" wx:if="{{eduForm.degree !== '小学' && eduForm.degree !== '初中'}}">
        <text class="form-label">专业</text>
        <input class="form-input" placeholder="请输入所读专业名称" value="{{eduForm.major}}" data-field="major" bindinput="onEduFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">班级</text>
        <input class="form-input" placeholder="如：三年二班 / 通信 1001 班" value="{{eduForm.className}}" data-field="className" bindinput="onEduFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">入学时间</text>
        <picker class="form-picker" mode="date" value="{{eduForm.enrollDate}}" start="1980-01" end="2030-12" bindchange="onEduEnrollDateChange">
          <view class="form-input">{{eduForm.enrollDate || '请选择'}}</view>
        </picker>
        <text class="form-arrow">></text>
      </view>
      <view class="form-row">
        <text class="form-label">毕业时间</text>
        <picker class="form-picker" mode="date" value="{{eduForm.graduateDate}}" start="1980-01" end="2030-12" bindchange="onEduGraduateDateChange">
          <view class="form-input">{{eduForm.graduateDate || '请选择'}}</view>
        </picker>
        <text class="form-arrow">></text>
      </view>
      <view class="sheet-actions">
        <view class="sheet-btn-delete" bindtap="deleteEdu">删除</view>
        <button class="sheet-btn-save" bindtap="saveEdu">保存</button>
      </view>
    </scroll-view>
  </view>

  <!-- 半屏：添加/编辑工作经历 -->
  <view class="sheet-mask" wx:if="{{showWorkSheet}}" bindtap="closeWorkSheet"></view>
  <view class="sheet-panel work-sheet {{showWorkSheet ? 'sheet-show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeWorkSheet">×</text>
      <text class="sheet-title">{{workEditIndex >= 0 ? '编辑工作经历' : '添加工作经历'}}</text>
    </view>
    <scroll-view class="sheet-body" scroll-y>
      <view class="form-row">
        <text class="form-label">公司 *</text>
        <input class="form-input" placeholder="必填" value="{{workForm.company}}" data-field="company" bindinput="onWorkFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">职位 *</text>
        <input class="form-input" placeholder="必填" value="{{workForm.title}}" data-field="title" bindinput="onWorkFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">部门</text>
        <input class="form-input" placeholder="请输入部门名称" value="{{workForm.department}}" data-field="department" bindinput="onWorkFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">入职时间</text>
        <picker class="form-picker" mode="date" value="{{workForm.startDate}}" start="1980-01" end="2030-12" bindchange="onWorkStartDateChange">
          <view class="form-input">{{workForm.startDate || '请选择'}}</view>
        </picker>
        <text class="form-arrow">></text>
      </view>
      <view class="form-row form-row-with-switch">
        <text class="form-label">离职时间</text>
        <picker class="form-picker" mode="date" value="{{workForm.endDate}}" start="1980-01" end="2030-12" bindchange="onWorkEndDateChange">
          <view class="form-input">{{workForm.endDate || '请选择'}}</view>
        </picker>
        <view class="work-current-wrap">
          <switch class="work-current-switch" checked="{{workForm.currentJob}}" bindchange="onWorkFormSwitch" />
          <text class="work-current-label">当前在职</text>
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">经历描述</text>
        <textarea class="form-input multi-line" placeholder="填写相关经历描述" value="{{workForm.description}}" data-field="description" bindinput="onWorkFormInput" />
      </view>
      <view class="sheet-actions">
        <view class="sheet-btn-delete" bindtap="deleteWork">删除</view>
        <button class="sheet-btn-save" bindtap="saveWork">保存</button>
      </view>
    </scroll-view>
  </view>

  <!-- 半屏：编辑脱单 -->
  <view class="sheet-mask" wx:if="{{showDatingSheet}}" bindtap="closeDatingSheet"></view>
  <view class="sheet-panel edu-sheet {{showDatingSheet ? 'sheet-show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeDatingSheet">×</text>
      <text class="sheet-title">添加交友匹配需求</text>
    </view>
    <scroll-view class="sheet-body" scroll-y>
      <view class="form-row">
        <text class="form-label">婚姻状况</text>
        <view class="option-chip-row">
          <view
            class="option-chip {{item.value === marital_status ? 'option-chip-selected' : ''}}"
            wx:for="{{maritalOptions}}"
            wx:key="value"
            data-value="{{item.value}}"
            data-label="{{item.label}}"
            bindtap="onMaritalStatusTap"
          >
            {{item.label}}
          </view>
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">相亲偏好</text>
        <textarea class="form-input multi-line" placeholder="请描述您的相亲偏好..." value="{{datingPreferences}}" data-field="datingPreferences" bindinput="onInputChange" />
      </view>
      <view class="sheet-actions">
        <button class="sheet-btn-save" bindtap="saveDating">保存</button>
      </view>
    </scroll-view>
  </view>

  <!-- 半屏：编辑求职 -->
  <view class="sheet-mask" wx:if="{{showJobSheet}}" bindtap="closeJobSheet"></view>
  <view class="sheet-panel edu-sheet {{showJobSheet ? 'sheet-show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeJobSheet">×</text>
      <text class="sheet-title">添加求职需求</text>
    </view>
    <scroll-view class="sheet-body" scroll-y>
      <view class="form-row">
        <text class="form-label">目标职位</text>
        <input class="form-input" placeholder="目标职位" value="{{jobTargetPosition}}" data-field="jobTargetPosition" bindinput="onInputChange" />
      </view>
      <view class="form-row">
        <text class="form-label">目标行业</text>
        <input class="form-input" placeholder="目标行业" value="{{jobTargetIndustry}}" data-field="jobTargetIndustry" bindinput="onInputChange" />
      </view>
      <view class="form-row">
        <text class="form-label">工作偏好</text>
        <textarea class="form-input multi-line" placeholder="工作偏好" value="{{jobPreferences}}" data-field="jobPreferences" bindinput="onInputChange" />
      </view>
      <view class="sheet-actions">
        <button class="sheet-btn-save" bindtap="saveJob">保存</button>
      </view>
    </scroll-view>
  </view>

  <!-- 半屏：编辑创业 -->
  <view class="sheet-mask" wx:if="{{showEntreSheet}}" bindtap="closeEntreSheet"></view>
  <view class="sheet-panel edu-sheet {{showEntreSheet ? 'sheet-show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeEntreSheet">×</text>
      <text class="sheet-title">添加创业匹配需求</text>
    </view>
    <scroll-view class="sheet-body" scroll-y>
      <view class="form-row">
        <text class="form-label">需求类型</text>
        <view class="option-chip-row">
          <view
            class="option-chip {{item.value === entrepreneurship_type ? 'option-chip-selected' : ''}}"
            wx:for="{{entrepreneurshipTypeOptions}}"
            wx:key="value"
            data-value="{{item.value}}"
            data-label="{{item.label}}"
            bindtap="onEntrepreneurshipTypeTap"
          >
            {{item.label}}
          </view>
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">创业描述</text>
        <textarea class="form-input multi-line" placeholder="请描述您的创业需求..." value="{{entrepreneurshipDescription}}" data-field="entrepreneurshipDescription" bindinput="onInputChange" />
      </view>
      <view class="sheet-actions">
        <button class="sheet-btn-save" bindtap="saveEntre">保存</button>
      </view>
    </scroll-view>
  </view>

  <!-- 半屏：添加/编辑资源 -->
  <view class="sheet-mask" wx:if="{{showResourceSheet}}" bindtap="closeResourceSheet"></view>
  <view class="sheet-panel edu-sheet {{showResourceSheet ? 'sheet-show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeResourceSheet">×</text>
      <text class="sheet-title">{{resourceEditIndex >= 0 ? '编辑资源' : '添加资源'}}</text>
    </view>
    <scroll-view class="sheet-body" scroll-y>
      <view class="form-row">
        <text class="form-label">类型</text>
        <view class="option-chip-row">
          <view
            class="option-chip {{item.value === resourceForm.resource_type ? 'option-chip-selected' : ''}}"
            wx:for="{{resourceTypeOptions}}"
            wx:key="value"
            data-value="{{item.value}}"
            data-label="{{item.label}}"
            bindtap="onResourceFormTypeTap"
          >
            {{item.label}}
          </view>
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">标题</text>
        <input class="form-input" placeholder="资源标题" value="{{resourceForm.resource_title}}" data-field="resource_title" bindinput="onResourceFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">描述</text>
        <textarea class="form-input multi-line" placeholder="资源描述" value="{{resourceForm.resource_description}}" data-field="resource_description" bindinput="onResourceFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">分享方式</text>
        <view class="option-chip-row">
          <view
            class="option-chip {{item.value === resourceForm.sharing_mode ? 'option-chip-selected' : ''}}"
            wx:for="{{sharingModeOptions}}"
            wx:key="value"
            data-value="{{item.value}}"
            data-label="{{item.label}}"
            bindtap="onResourceFormModeTap"
          >
            {{item.label}}
          </view>
        </view>
      </view>
      <view class="sheet-actions">
        <view class="sheet-btn-delete" wx:if="{{resourceEditIndex >= 0}}" bindtap="deleteResource">删除</view>
        <button class="sheet-btn-save" bindtap="saveResource">保存</button>
      </view>
    </scroll-view>
  </view>

  <!-- 半屏：添加/编辑自我简介卡片 -->
  <view class="sheet-mask" wx:if="{{showIntroSheet}}" bindtap="closeIntroSheet"></view>
  <view class="sheet-panel edu-sheet {{showIntroSheet ? 'sheet-show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeIntroSheet">×</text>
      <text class="sheet-title">{{introEditIndex >= 0 ? '编辑简介' : '添加简介'}}</text>
    </view>
    <scroll-view class="sheet-body" scroll-y>
      <view class="form-row">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="姓名" value="{{introForm.name}}" data-field="name" bindinput="onIntroFormInput" />
      </view>
      <view class="form-row" bindtap="onIntroPhotoTap">
        <text class="form-label">照片</text>
        <image class="form-avatar" wx:if="{{introForm.photo}}" src="{{introForm.photo}}" mode="aspectFill" />
        <text class="form-input form-input-placeholder" wx:else>点击选择</text>
        <text class="form-arrow">></text>
      </view>
      <view class="form-row">
        <text class="form-label">简介文字</text>
        <textarea
          class="form-input multi-line intro-textarea"
          placeholder="{{introPlaceholder}}"
          value="{{introForm.introText}}"
          data-field="introText"
          bindinput="onIntroFormInput"
        />
      </view>
      <view class="form-row">
        <text class="form-label">适用场景</text>
        <input class="form-input" placeholder="如：线下活动、线上对接" value="{{introForm.scene}}" data-field="scene" bindinput="onIntroFormInput" />
      </view>
      <view class="sheet-actions">
        <view class="sheet-btn-delete" wx:if="{{introEditIndex >= 0}}" bindtap="deleteIntroCard">删除</view>
        <button class="sheet-btn-save" bindtap="saveIntroCard">保存</button>
      </view>
    </scroll-view>
  </view>

  <!-- 半屏：我的需求 - 选择添加类型（九宫格 icon+文字） -->
  <view class="sheet-mask" wx:if="{{showNeedTypeSheet}}" bindtap="closeNeedTypeSheet"></view>
  <view class="sheet-panel edu-sheet {{showNeedTypeSheet ? 'sheet-show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeNeedTypeSheet">×</text>
      <text class="sheet-title">添加需求类型</text>
    </view>
    <view class="need-type-grid">
      <view class="need-type-item" wx:for="{{needTypeGrid}}" wx:key="type" data-type="{{item.type}}" bindtap="onSelectNeedType">
        <text class="need-type-icon">{{item.icon}}</text>
        <text class="need-type-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 半屏：设置可见性（公开/私密/打码/好友/校友） -->
  <view class="sheet-mask" wx:if="{{showVisibilitySheet}}" bindtap="closeVisibilitySheet"></view>
  <view class="sheet-panel edu-sheet {{showVisibilitySheet ? 'sheet-show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-close" bindtap="closeVisibilitySheet">×</text>
      <text class="sheet-title">可见性：{{visibilityEditingLabel}}</text>
    </view>
    <scroll-view class="sheet-body" scroll-y>
      <view class="visibility-option-row {{item.value === visibilityEditingValue ? 'visibility-option-selected' : ''}}" wx:for="{{visibilityOptions}}" wx:key="value" data-value="{{item.value}}" bindtap="onSelectVisibility">
        <text class="visibility-option-icon">{{item.icon}}</text>
        <text class="visibility-option-label">{{item.label}}</text>
      </view>
    </scroll-view>
  </view>
</view>
