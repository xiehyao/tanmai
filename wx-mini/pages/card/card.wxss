/* pages/card/card.wxss */
.card-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.card-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.card-header-own {
  position: relative;
}

.card-header-hover {
  opacity: 0.92;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-bottom: 20rpx;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.work-wechat {
  font-size: 24rpx;
  opacity: 0.9;
}

.card-content {
  margin-top: 20rpx;
  background: #fff;
  padding: 40rpx;
}

.info-item {
  display: flex;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}

.label {
  font-size: 28rpx;
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.actions {
  padding: 40rpx;
}

.actions-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 24rpx;
}

.actions-row::after {
  display: none;
}

.actions button,
.primary-btn {
  background: #667eea;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx;
  width: 100%;
}

.actions-row .primary-btn.flex-1 {
  flex: 1;
  width: auto;
  margin: 0;
}

.actions-row .primary-btn::after {
  border: none;
}

.secondary-btn {
  background: #fff;
  color: #667eea;
  border: 2rpx solid rgba(102, 126, 234, 0.45);
}

.secondary-btn::after {
  border: none;
}

.preview-btn {
  flex: 0 0 auto;
  box-sizing: border-box;
  width: 88rpx;
  min-width: 88rpx;
  max-width: 88rpx;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.preview-icon {
  font-size: 36rpx;
  line-height: 1;
}

